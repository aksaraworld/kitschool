rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['saas_admin', 'principal'];
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        getUserRole() in ['saas_admin', 'principal', 'staff']
      );
      allow create: if isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if getUserRole() == 'saas_admin';
    }
    
    // Schools collection
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create: if getUserRole() == 'saas_admin';
      allow update: if isAdmin();
      allow delete: if getUserRole() == 'saas_admin';
    }
    
    // Classes collection
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Students collection (if separate from users)
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Attendance collection
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Students can create their own attendance
      allow update, delete: if isAdmin();
    }
    
    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if getUserRole() in ['saas_admin', 'principal', 'finance'];
    }
    
    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if getUserRole() in ['saas_admin', 'principal', 'finance'];
    }
    
    // Schedules collection
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Communications collection (legacy)
    match /communications/{communicationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.senderId) || isAdmin();
    }

    // Chat monthly backups (per user, downloadable from settings)
    match /chatBackups/{backupId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
      match /entries/{entryId} {
        allow read: if isAuthenticated() &&
          get(/databases/$(database)/documents/chatBackups/$(backupId)).data.userId == request.auth.uid;
        allow write: if false;
      }
    }

    match /publicChatSessions/{sessionId} {
      allow read, write: if false;
    }

    match /publicChatRateLimits/{docId} {
      allow read, write: if false;
    }

    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        getUserRole() in ['saas_admin', 'principal', 'staff', 'teacher', 'homeroom_teacher', 'finance']
      );
      allow create, update: if false;
    }

    // School chat
    match /chatConversations/{conversationId} {
      allow read, update: if isAuthenticated() &&
        request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated();
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chatConversations/$(conversationId)).data.participantIds;
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/chatConversations/$(conversationId)).data.participantIds &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    match /boardingAreas/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /boardingRooms/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /boardingSchedules/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Years collection
    match /years/{yearId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Majors collection
    match /majors/{majorId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Config collection
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if getUserRole() == 'saas_admin';
    }
    
    // Payment attempts (for invoices)
    match /paymentAttempts/{paymentAttemptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if getUserRole() in ['saas_admin', 'principal', 'finance'];
    }
    
    // Transaction fees (SaaS)
    match /transactionFees/{docId} {
      allow read: if isAuthenticated();
      allow write: if getUserRole() == 'saas_admin';
    }
    
    // Student activities (e.g. parent view)
    match /studentActivities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // Medical records (student health)
    match /medicalRecords/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Admissions (applications)
    match /admissions/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Fee structures (tuition, bus, lab, etc.)
    match /feeStructures/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if getUserRole() in ['saas_admin', 'principal', 'finance'];
    }
    
    // Leave requests (staff)
    match /leaveRequests/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // Payroll logs
    match /payrollLogs/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if getUserRole() in ['saas_admin', 'principal', 'finance'];
    }
    
    // Subjects (for exams, schedules)
    match /subjects/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Rooms (classrooms)
    match /rooms/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Exams
    match /exams/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Grades
    match /grades/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Assignments (LMS)
    match /assignments/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Submissions (LMS)
    match /submissions/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // Resources (LMS materials)
    match /resources/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
  }
}
