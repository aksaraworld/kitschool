{
  "name": "cognifa-backend",
  "version": "1.0.0",
  "description": "Backend API for Cognifa",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",
    "drop-db": "tsx src/scripts/drop-database.ts",
    "reset-db": "npm run drop-db && npm run seed",
    "check-db": "node check-mongodb.js",
    "migrate:firebase": "tsx src/scripts/migrate-to-firebase.ts",
    "bootstrap:firebase": "tsx src/scripts/bootstrap-firestore.ts",
    "migrate:firebase:all": "tsx src/scripts/migrate-all-to-firebase.ts",
    "demo:auth": "tsx src/scripts/set-demo-auth-passwords.ts",
    "seed:firebase": "tsx src/scripts/reset-and-seed-50.ts && tsx src/scripts/seed-new-modules.ts",
    "seed:firebase:reset": "tsx src/scripts/reset-and-seed-50.ts",
    "seed:firebase:modules": "tsx src/scripts/seed-new-modules.ts",
    "seed:kitschool": "tsx src/scripts/seed-kitschool-ppst.ts",
    "seed:demo-modules": "tsx src/scripts/seed-ppst-demo-modules.ts"
  },
  "dependencies": {
    "@aksara/firebase": "file:../packages/firebase",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "esbuild": "^0.27.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}