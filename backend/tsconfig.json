{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/scripts/**/*",
    "src/config/firebase-adc.ts",
    "src/middleware/auth.ts",
    "src/routes/auth.ts",
    "src/routes/users.ts",
    "src/routes/invoices.ts",
    "src/routes/reports.ts",
    "src/routes/config.ts",
    "src/routes/transaction-fees.ts"
  ]
}


