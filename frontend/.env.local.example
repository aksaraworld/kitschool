# Copy to frontend/.env.local and fill in values (do not commit .env.local)
# See MAC_HANDOFF.md, FIREBASE_CONNECT.md, LOCAL_LOGIN_SETUP.md

# --- Firebase client (browser) — Firebase Console → Project settings → Your apps ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cognifa-16209.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cognifa-16209
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cognifa-16209.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- API (leave empty for local Next.js /api routes) ---
# NEXT_PUBLIC_API_URL=

# --- Firebase Admin (server /api routes, login) — pick ONE approach ---

# Option A: path to service account JSON (relative to frontend/)
FIREBASE_PROJECT_ID=cognifa-16209
FIREBASE_SERVICE_ACCOUNT_PATH=../cognifa-16209-firebase-adminsdk-fbsvc-47ae77c666.json

# Option B: inline credentials (e.g. Vercel) — comment out Option A if using these
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@cognifa-16209.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
